{
  "regions": [
    "fra1"
  ],
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install --no-audit --prefer-offline --no-fund",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/telegram/daily-evening",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/parser-cleanup",
      "schedule": "0 1 * * *"
    }
  ],
  "git": {
    "deploymentEnabled": false
  }
}
