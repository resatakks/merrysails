{
  "regions": [
    "fra1"
  ],
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install --no-audit --prefer-offline --no-fund",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/telegram/daily-evening",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/google-ads/safety-check",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/google-ads/budget-review",
      "schedule": "0 6 * * 1"
    }
  ],
  "git": {
    "deploymentEnabled": true
  }
}