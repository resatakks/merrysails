{
  "regions": [
    "fra1"
  ],
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/telegram/daily-morning",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/telegram/daily-evening",
      "schedule": "30 15 * * *"
    },
    {
      "path": "/api/telegram/daily-stats",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/telegram/reminder",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/telegram/reminder",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/google-ads/safety-check",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/google-ads/budget-review",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/gsc/snapshot",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/seo/rankings",
      "schedule": "30 7 * * 1"
    }
  ],
  "git": {
    "deploymentEnabled": false
  }
}
