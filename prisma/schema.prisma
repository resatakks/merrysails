generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Reservation ────────────────────────────────────────────

model Reservation {
  id            String   @id @default(cuid())
  reservationId String   @unique // MRY-2026-0001
  tourSlug      String
  tourName      String
  date          DateTime
  time          String // "17:00", "19:30" etc.
  guests        Int
  totalPrice    Float
  currency      String   @default("EUR")
  status        String   @default("new") // new | confirmed | cancelled | completed
  internalCostEur Float?
  confirmedAt   DateTime?
  completedAt   DateTime?

  // Customer info
  customerName    String
  customerEmail   String
  customerPhone   String
  customerCountry String?
  notes           String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([date])
  @@index([customerEmail])
  @@index([createdAt])
}

// ─── Telegram User ──────────────────────────────────────────

model TelegramUser {
  chatId         String  @id
  username       String?
  firstName      String?
  isActive       Boolean @default(true)
  notifyNew      Boolean @default(true)
  notifyReminder Boolean @default(true)
  notifyDaily    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Contact Message ────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Google Ads Lead Forms ─────────────────────────────────

model GoogleAdsLead {
  id           String   @id @default(cuid())
  googleLeadId String?  @unique
  formId       String?
  campaignId   String?
  campaignName String?
  product      String?
  source       String   @default("google_ads_lead_form")
  name         String?
  phone        String?
  email        String?
  isTest       Boolean  @default(false)
  status       String   @default("new") // new | contacted | qualified | bad | booked
  rawPayload   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([campaignName])
  @@index([phone])
  @@index([status])
}

// ─── Tour Operations ──────────────────────────────────────

model TourOperationDay {
  id                    String   @id @default(cuid())
  tourSlug              String
  date                  DateTime
  isSoldOut             Boolean  @default(false)
  departureTimeOverride String?
  note                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tourSlug, date])
  @@index([date])
  @@index([tourSlug])
}

model BookingPrefill {
  id        String   @id @default(cuid())
  tourSlug  String
  payload   Json
  source    String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@index([tourSlug, createdAt])
}

// ─── AI & Bot Visit Tracking ──────────────────────────────

model BotVisit {
  id        String   @id @default(cuid())
  provider  String   // openai | anthropic | perplexity | google-ai | meta | bing | yandex | other
  agent     String   // GPTBot | ClaudeBot | PerplexityBot | etc.
  path      String
  ip        String?
  country   String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([provider])
  @@index([path])
}
