generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Reservation ────────────────────────────────────────────

model Reservation {
  id            String   @id @default(cuid())
  reservationId String   @unique // MRY-2026-0001
  tourSlug      String
  tourName      String
  date          DateTime
  time          String // "17:00", "19:30" etc.
  guests        Int
  totalPrice    Float
  currency      String   @default("EUR")
  status        String   @default("new") // new | confirmed | cancelled | completed
  internalCostEur Float?
  confirmedAt   DateTime?
  completedAt   DateTime?
  /// Multi-package booking line items. When present and has ≥2 entries this
  /// is a mixed-package booking (e.g. some guests on alcohol, others on
  /// soft-drinks). null / single-item = legacy single-package booking;
  /// renderers fall back to the existing pricing snapshot in that case.
  items         Json?

  // Customer info
  customerName    String
  customerEmail   String
  customerPhone   String
  customerCountry String?
  notes           String?

  // Traffic attribution (captured at submit time from sessionStorage)
  // Required for server-side Google Ads conversion uploads & multi-touch attribution.
  gclid         String?
  gbraid        String?
  wbraid        String?
  gadSource     String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  referrerHost  String?
  landingPath   String?
  trafficChannel String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([date])
  @@index([customerEmail])
  @@index([createdAt])
  @@index([gclid])
  @@index([utmCampaign])
}

// ─── External Job ───────────────────────────────────────────
// Bookings/voucher+invoice generated on behalf of OTHER companies.
// Independent from the website's own tours — the voucher/invoice
// PDF renders the EXTERNAL company's logo + tax/address details,
// not MerrySails brand.

model ExternalJob {
  id    String @id @default(cuid())
  jobId String @unique // EXT-MRY-2026-0001

  // Event type — drives the front-end template that pre-fills inclusions,
  // duration, voucher title. Free-text fallback "custom".
  eventType    String  @default("custom") // engagement | birthday | wedding | corporate | family | custom

  // Optional B2B "Bill to" company. When present, invoice shows a Bill-to
  // block with companyName + taxId + address. When null, invoice renders as
  // a normal B2C customer invoice. Voucher/invoice branding is ALWAYS
  // MerrySails — companyLogoUrl is no longer used to override the header.
  companyName    String?
  companyAddress String?
  companyTaxId   String?
  companyEmail   String?
  companyPhone   String?
  companyLogoUrl String?

  // End customer
  customerName    String
  customerEmail   String?
  customerPhone   String?
  customerCountry String?

  // Service / job details
  serviceTitle       String
  serviceDescription String?
  jobDate            DateTime
  jobTime            String?
  durationHours      Float?
  guests             Int     @default(1)
  pickupPoint        String?

  // What's included on board — bulleted list rendered on voucher.
  // e.g. ["Catering & food service", "Table decorations", "Music speaker"]
  inclusions       String[] @default([])
  voucherExtraTitle String? // e.g. "Engagement Package & Schedule"

  // Pricing & payment
  amount          Float
  currency        String  @default("EUR")
  paymentMethod   String  @default("cash_on_board") // cash_on_board | card_on_board | card_paid | bank_transfer
  paymentStatus   String  @default("pending") // pending | paid | refunded
  paymentNotes    String? // free-text payment instructions for voucher/invoice
  internalCostEur Float?

  // Status & ops
  status       String  @default("new") // new | confirmed | completed | cancelled
  notes        String?
  internalNote String?

  // Email tracking
  emailSent      Boolean   @default(false)
  emailSentAt    DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  @@index([status])
  @@index([jobDate])
  @@index([companyName])
  @@index([eventType])
  @@index([createdAt])
}

// ─── Telegram User ──────────────────────────────────────────

model TelegramUser {
  chatId         String  @id
  username       String?
  firstName      String?
  isActive       Boolean @default(true)
  notifyNew      Boolean @default(true)
  notifyReminder Boolean @default(true)
  notifyDaily    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Contact Message ────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)

  // Traffic attribution (captured at submit time from sessionStorage)
  gclid         String?
  gbraid        String?
  wbraid        String?
  gadSource     String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  referrerHost  String?
  landingPath   String?
  trafficChannel String?

  createdAt DateTime @default(now())

  @@index([gclid])
  @@index([utmCampaign])
}

// ─── Google Ads Lead Forms ─────────────────────────────────

model GoogleAdsLead {
  id           String   @id @default(cuid())
  googleLeadId String?  @unique
  formId       String?
  campaignId   String?
  campaignName String?
  product      String?
  source       String   @default("google_ads_lead_form")
  name         String?
  phone        String?
  email        String?
  isTest       Boolean  @default(false)
  status       String   @default("new") // new | contacted | qualified | bad | booked
  rawPayload   Json

  // Lead form payloads include `gcl_id` (Google Click ID) when forwarded
  // through user-column extras — required for server-side conversion upload.
  gclid        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([campaignName])
  @@index([phone])
  @@index([status])
  @@index([gclid])
}

// ─── Tour Operations ──────────────────────────────────────

model TourOperationDay {
  id                    String   @id @default(cuid())
  tourSlug              String
  date                  DateTime
  isSoldOut             Boolean  @default(false)
  departureTimeOverride String?
  note                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tourSlug, date])
  @@index([date])
  @@index([tourSlug])
}

model BookingPrefill {
  id        String   @id @default(cuid())
  tourSlug  String
  payload   Json
  source    String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@index([tourSlug, createdAt])
}

// ─── AI & Bot Visit Tracking ──────────────────────────────

model BotVisit {
  id        String   @id @default(cuid())
  provider  String   // openai | anthropic | perplexity | google-ai | meta | bing | yandex | other
  agent     String   // GPTBot | ClaudeBot | PerplexityBot | etc.
  path      String
  ip        String?
  country   String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([provider])
  @@index([path])
}

// ─── SEO Rankings (DataForSEO) ────────────────────────────

model SeoRanking {
  id           String   @id @default(cuid())
  domain       String
  keyword      String
  locationCode Int
  languageCode String
  rank         Int?     // 1-based organic position; null = not in top 100
  url          String?
  title        String?
  snippet      String?
  totalResults Int      @default(0)
  checkedAt    DateTime @default(now())

  @@index([domain, keyword])
  @@index([domain, checkedAt])
  @@index([checkedAt])
}

model SeoBacklink {
  id               String   @id @default(cuid())
  domain           String
  totalBacklinks   Int      @default(0)
  referringDomains Int      @default(0)
  domainRank       Int      @default(0)
  checkedAt        DateTime @default(now())

  @@index([domain, checkedAt])
}

// ─── Disavow Audit Snapshots ──────────────────────────────
// Each run stores the full toxic refdom list so we can diff against the previous run.
model DisavowSnapshot {
  id           String   @id @default(cuid())
  domain       String   // e.g. "merrysails.com"
  runAt        DateTime @default(now())
  totalRefdoms Int
  toxicCount   Int
  reviewCount  Int
  // [{ domain, spamScore, rank, backlinks, reason }]
  toxic        Json
  // [{ domain, spamScore, rank, backlinks }]
  review       Json?

  @@index([domain, runAt])
}

model SeoLlmMention {
  id        String   @id @default(cuid())
  domain    String
  query     String
  model     String   // perplexity | chatgpt | gemini
  mentioned Boolean
  rank      Int?
  snippet   String?
  checkedAt DateTime @default(now())

  @@index([domain, checkedAt])
  @@index([domain, mentioned])
}

// ─── GSC Daily Snapshots ──────────────────────────────────

model GscSnapshot {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  // Site-wide totals
  clicks      Int
  impressions Int
  ctr         Float    // 0.0–1.0
  position    Float    // avg position
  // Top page data (JSON array: [{page, clicks, impressions, ctr, position}])
  topPages    Json?
  // Top queries (JSON array: [{query, clicks, impressions, ctr, position}])
  topQueries  Json?
  createdAt   DateTime @default(now())

  @@unique([date])
  @@index([date])
}

// ─── Performance Snapshots (Lighthouse / PageSpeed Insights) ─────

model PerformanceSnapshot {
  id                 String   @id @default(cuid())
  url                String
  strategy           String   // mobile | desktop
  performanceScore   Float?
  seoScore           Float?
  accessibilityScore Float?
  bestPracticesScore Float?
  fcp                Float?   // First Contentful Paint (ms)
  lcp                Float?   // Largest Contentful Paint (ms)
  tbt                Float?   // Total Blocking Time (ms)
  cls                Float?   // Cumulative Layout Shift
  si                 Float?   // Speed Index (ms)
  tti                Float?   // Time to Interactive (ms)
  snapshotAt         DateTime @default(now())

  @@index([url, strategy, snapshotAt])
  @@index([snapshotAt])
}

// ─── LLM Brand Mention Tracking ──────────────────────────────────

model LlmMention {
  id              String   @id @default(cuid())
  keyword         String
  llm             String   // chatgpt | perplexity | claude | gemini
  brandMentioned  Boolean  @default(false)
  brandPosition   Int      @default(0) // 0 = not mentioned; 1-based position otherwise
  citationContext String?  // sentence quoting brand if present
  snapshotAt      DateTime @default(now())

  @@index([keyword, llm, snapshotAt])
  @@index([snapshotAt])
}

// ─── Newsletter Subscribers ──────────────────────────────────────

model NewsletterSubscriber {
  id          String    @id @default(cuid())
  email       String    @unique
  source      String    @default("footer")
  locale      String    @default("en")
  confirmedAt DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([source])
}

// ─── Post-booking review request (operator-pending Twilio approval) ───
// Tracks WhatsApp review-request messages sent 24-72h after a completed
// reservation. Skeleton state — cron route exists but is gated on
// WHATSAPP_API_TOKEN being set. See:
//   src/app/api/cron/review-request/route.ts
//   ~/.agents/scripts/manual-helpers/whatsapp-review-request-template.ts

model ReviewRequest {
  id            String   @id @default(cuid())
  reservationId String   @unique // FK by value to Reservation.reservationId
  customerPhone String
  customerName  String
  locale        String   @default("en")
  channel       String   @default("whatsapp") // whatsapp | sms | email
  status        String   @default("pending")  // pending | sent | failed | skipped
  providerMsgId String? // Twilio SID or Cloud API message id
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}
