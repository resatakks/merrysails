generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Reservation ────────────────────────────────────────────

model Reservation {
  id            String   @id @default(cuid())
  reservationId String   @unique // MRY-2026-0001
  tourSlug      String
  tourName      String
  date          DateTime
  time          String // "17:00", "19:30" etc.
  guests        Int
  totalPrice    Float
  currency      String   @default("EUR")
  status        String   @default("new") // new | confirmed | cancelled | completed
  internalCostEur Float?
  confirmedAt   DateTime?
  completedAt   DateTime?

  // Customer info
  customerName    String
  customerEmail   String
  customerPhone   String
  customerCountry String?
  notes           String?

  // Traffic attribution (captured at submit time from sessionStorage)
  // Required for server-side Google Ads conversion uploads & multi-touch attribution.
  gclid         String?
  gbraid        String?
  wbraid        String?
  gadSource     String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  referrerHost  String?
  landingPath   String?
  trafficChannel String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([date])
  @@index([customerEmail])
  @@index([createdAt])
  @@index([gclid])
  @@index([utmCampaign])
}

// ─── Telegram User ──────────────────────────────────────────

model TelegramUser {
  chatId         String  @id
  username       String?
  firstName      String?
  isActive       Boolean @default(true)
  notifyNew      Boolean @default(true)
  notifyReminder Boolean @default(true)
  notifyDaily    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Contact Message ────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)

  // Traffic attribution (captured at submit time from sessionStorage)
  gclid         String?
  gbraid        String?
  wbraid        String?
  gadSource     String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  referrerHost  String?
  landingPath   String?
  trafficChannel String?

  createdAt DateTime @default(now())

  @@index([gclid])
  @@index([utmCampaign])
}

// ─── Google Ads Lead Forms ─────────────────────────────────

model GoogleAdsLead {
  id           String   @id @default(cuid())
  googleLeadId String?  @unique
  formId       String?
  campaignId   String?
  campaignName String?
  product      String?
  source       String   @default("google_ads_lead_form")
  name         String?
  phone        String?
  email        String?
  isTest       Boolean  @default(false)
  status       String   @default("new") // new | contacted | qualified | bad | booked
  rawPayload   Json

  // Lead form payloads include `gcl_id` (Google Click ID) when forwarded
  // through user-column extras — required for server-side conversion upload.
  gclid        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([campaignName])
  @@index([phone])
  @@index([status])
  @@index([gclid])
}

// ─── Tour Operations ──────────────────────────────────────

model TourOperationDay {
  id                    String   @id @default(cuid())
  tourSlug              String
  date                  DateTime
  isSoldOut             Boolean  @default(false)
  departureTimeOverride String?
  note                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tourSlug, date])
  @@index([date])
  @@index([tourSlug])
}

model BookingPrefill {
  id        String   @id @default(cuid())
  tourSlug  String
  payload   Json
  source    String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@index([tourSlug, createdAt])
}

// ─── AI & Bot Visit Tracking ──────────────────────────────

model BotVisit {
  id        String   @id @default(cuid())
  provider  String   // openai | anthropic | perplexity | google-ai | meta | bing | yandex | other
  agent     String   // GPTBot | ClaudeBot | PerplexityBot | etc.
  path      String
  ip        String?
  country   String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([provider])
  @@index([path])
}

// ─── GSC Daily Snapshots ──────────────────────────────────

model GscSnapshot {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  // Site-wide totals
  clicks      Int
  impressions Int
  ctr         Float    // 0.0–1.0
  position    Float    // avg position
  // Top page data (JSON array: [{page, clicks, impressions, ctr, position}])
  topPages    Json?
  // Top queries (JSON array: [{query, clicks, impressions, ctr, position}])
  topQueries  Json?
  createdAt   DateTime @default(now())

  @@unique([date])
  @@index([date])
}
